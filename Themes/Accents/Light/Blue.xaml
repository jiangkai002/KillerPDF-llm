<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Light family - BLUE accent overlay. Accent is a true blue (readable on white, and the
         selected-page background with white text); the dim key is a pale tint for the highlight
         background. Fixed greens (InstallBtnBg, AccentLogo) come from Light.xaml. -->
    <SolidColorBrush x:Key="Accent"          Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderAccent"    Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"       Color="#D6E8F5" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionBg"     Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb"   Color="#881D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="RadioAccent"     Color="#1D6CA5" po:Freeze="True"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#D6E8F5" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#1D6CA5" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#D6E8F5" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1D6CA5" po:Freeze="True"/>

</ResourceDictionary>
