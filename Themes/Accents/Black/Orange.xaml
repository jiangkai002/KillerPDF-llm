<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Black family - ORANGE neon accent overlay. Fixed greens (InstallBtnBg, AccentLogo) come
         from HighContrast.xaml. -->
    <SolidColorBrush x:Key="Accent"          Color="#FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderAccent"    Color="#FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"       Color="#381F00" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionBg"     Color="#381F00" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionFg"     Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb"   Color="#88FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="RadioAccent"     Color="#FF910A" po:Freeze="True"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#381F00" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#FF910A" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#381F00" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF910A" po:Freeze="True"/>

</ResourceDictionary>
