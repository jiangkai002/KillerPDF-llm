<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Black family - PURPLE neon accent overlay. Fixed greens (InstallBtnBg, AccentLogo) come
         from HighContrast.xaml. -->
    <SolidColorBrush x:Key="Accent"          Color="#B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderAccent"    Color="#B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"       Color="#250038" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionBg"     Color="#250038" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionFg"     Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb"   Color="#88B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="RadioAccent"     Color="#B829FF" po:Freeze="True"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#250038" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#B829FF" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#250038" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#B829FF" po:Freeze="True"/>

</ResourceDictionary>
